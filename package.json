{
  "name": "1dex-connector-workspace",
  "type": "module",
  "workspaces": [
    "packages/js",
    "cli"
  ],
  "scripts": {
    "build:docs": "node ./scripts/build-docs-site.mjs",
    "check:package-cli": "node ./scripts/check-npm-console-package.mjs",
    "check:site": "node ./scripts/check-public-site.mjs",
    "check:openapi": "node ./scripts/check-openapi-parity.mjs",
    "test": "node --test packages/js/test/*.test.mjs cli/test/*.test.mjs",
    "test:python": "node ./scripts/run-python-tests.mjs",
    "test:all": "npm test && npm run test:python",
    "ci": "npm run build:docs && npm run check:site && npm run check:openapi && npm run test:all && npm run check:package-cli"
  },
  "engines": {
    "node": ">=22"
  }
}
